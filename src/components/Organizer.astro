---
import { useTranslations, type Lang } from "../i18n/utils";

interface Props {
    lang?: Lang;
}

const { lang = "es" } = Astro.props;
const t = useTranslations(lang);
---

<section class="section organizer-section" id="organizer">
    <div class="container">
        <div class="organizer-grid">
            <div class="organizer-image">
                <img
                    src="/images/JorgeNel.webp"
                    alt="Jorge Nel Giraldo"
                    width="500"
                    height="600"
                    loading="lazy"
                    decoding="async"
                />
            </div>
            <div class="organizer-content">
                <h2 class="organizer-name">{t.organizer.title}</h2>
                <p class="organizer-role">{t.organizer.subtitle}</p>
                <div class="organizer-bio">
                    {
                        t.organizer.bio.map((paragraph: string) => (
                            <p>{paragraph}</p>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .organizer-section {
        background: transparent;
    }

    .organizer-grid {
        display: grid;
        grid-template-columns: 1fr 1.5fr;
        gap: var(--spacing-3xl);
        align-items: start;
    }

    .organizer-image {
        position: relative;
    }

    .organizer-image img {
        width: 100%;
        height: auto;
        object-fit: cover;
    }

    .organizer-content {
        padding-top: var(--spacing-md);
    }

    .organizer-name {
        font-size: var(--font-size-2xl);
        font-weight: var(--font-weight-bold);
        color: var(--color-accent-gold);
        margin-bottom: var(--spacing-xs);
        letter-spacing: 0.05em;
    }

    .organizer-role {
        font-size: var(--font-size-sm);
        font-weight: var(--font-weight-medium);
        color: var(--color-text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: var(--spacing-lg);
    }

    .organizer-bio {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-md);
    }

    .organizer-bio p {
        font-size: 0.8rem;
        line-height: 1.7;
        color: var(--color-text-secondary);
    }

    /* Mobile: stack vertically */
    @media (max-width: 768px) {
        .organizer-grid {
            grid-template-columns: 1fr;
            gap: var(--spacing-xl);
        }

        .organizer-image {
            max-width: 300px;
            margin-inline: auto;
        }

        .organizer-content {
            text-align: center;
        }

        .organizer-bio p {
            text-align: left;
        }
    }
</style>
