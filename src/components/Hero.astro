---
import { useTranslations, type Lang } from "../i18n/utils";

interface Props {
  lang?: Lang;
}

const { lang = "es" } = Astro.props;
const t = useTranslations(lang);
---

<section class="hero" id="hero">
  <div class="hero-background">
    <!-- Background gradient layer -->
    <div class="hero-bg-image" aria-hidden="true"></div>
    <!-- Background texture layer -->
    <div class="hero-bg-texture" aria-hidden="true"></div>
    <!-- Overlay -->
    <div class="hero-overlay" aria-hidden="true"></div>
  </div>

  <div class="container hero-content">
    <!-- Logo placeholder -->
    <div class="hero-logo">
      <img
        src="/images/Logo.png"
        alt="Colombia Tango Festival Logo"
        width="200"
        height="200"
        loading="eager"
        decoding="async"
      />
    </div>

    <h1 class="hero-title">{t.hero.title}</h1>
    <p class="hero-subtitle">{t.hero.subtitle}</p>

    <div class="hero-date">
      <span class="hero-date-icon">📅</span>
      <span>{t.hero.date}</span>
    </div>

    <div class="hero-cta">
      <a
        href="https://docs.google.com/forms/d/e/1FAIpQLScX0vlhf5OUsbPuL85J85Fgft_X0c2G891pqdlTgxQfdT9ozQ/viewform"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-primary btn-lg"
      >
        {t.hero.cta}
      </a>
      <a href="#packages" class="btn btn-secondary btn-lg">
        {t.hero.ctaSecondary}
      </a>
    </div>
  </div>

  <!-- Foreground couple image - outside container for edge positioning -->
  <div class="hero-couple">
    <img
      src="/images/Bailarines.webp"
      alt={t.hero.dancersAlt}
      width="500"
      height="600"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
  </div>

  <!-- Scroll indicator -->
  <div class="hero-scroll" aria-hidden="true">
    <span class="scroll-indicator"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding-top: 80px; /* Header height */
  }

  .hero-background {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .hero-bg-image {
    position: absolute;
    inset: 0;
    /* Base gradient: dark gray to dark blue with subtle pink highlight */
    background:
      radial-gradient(
        ellipse at 80% 20%,
        rgba(219, 112, 147, 0.15) 0%,
        transparent 40%
      ),
      radial-gradient(
        ellipse at 20% 80%,
        rgba(219, 112, 147, 0.1) 0%,
        transparent 35%
      ),
      linear-gradient(135deg, #21201d 0%, #1a1f2e 40%, #0f1419 100%);
  }

  .hero-bg-texture {
    position: absolute;
    inset: 0;
    background: url("/images/BG_Bannerhero.jpg") center/cover no-repeat;
    opacity: 0.2;
    mix-blend-mode: overlay;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(33, 32, 29, 0.3) 0%,
      transparent 30%,
      transparent 70%,
      rgba(33, 32, 29, 0.8) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-block: var(--spacing-3xl);
  }

  .hero-logo {
    margin-bottom: var(--spacing-lg);
    animation: fadeInUp 0.6s ease forwards;
  }

  .hero-logo img {
    width: clamp(280px, 40vw, 450px);
    height: auto;
    object-fit: contain;
  }

  .hero-title {
    font-size: 0.75rem;
    font-weight: var(--font-weight-medium);
    line-height: var(--line-height-base);
    margin-bottom: var(--spacing-sm);
    animation: fadeInUp 0.6s ease 0.1s forwards;
    opacity: 0;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .hero-subtitle {
    font-size: var(--font-size-xl);
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-lg);
    animation: fadeInUp 0.6s ease 0.2s forwards;
    opacity: 0;
  }

  .hero-date {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-sm);
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--color-accent-gold);
    margin-bottom: var(--spacing-xl);
    animation: fadeInUp 0.6s ease 0.3s forwards;
    opacity: 0;
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-md);
    justify-content: center;
    animation: fadeInUp 0.6s ease 0.4s forwards;
    opacity: 0;
    margin-bottom: var(--spacing-3xl);
  }

  .btn-lg {
    padding: 10px 28px;
    font-size: 0.875rem;
  }

  .hero-couple {
    position: absolute;
    right: 0;
    bottom: 0;
    width: 30%;
    pointer-events: none;
    animation: fadeIn 1s ease 0.5s forwards;
    opacity: 0;
  }

  .hero-couple img {
    width: 100%;
    height: auto;
    object-fit: contain;
    object-position: right bottom;
  }

  .hero-scroll {
    position: absolute;
    bottom: var(--spacing-xl);
    left: 50%;
    transform: translateX(-50%);
  }

  .scroll-indicator {
    display: block;
    width: 24px;
    height: 40px;
    border: 2px solid var(--color-accent-gold);
    border-radius: 12px;
    position: relative;
  }

  .scroll-indicator::after {
    content: "";
    position: absolute;
    top: 6px;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    height: 8px;
    background: var(--color-accent-gold);
    border-radius: 2px;
    animation: scrollBounce 2s ease-in-out infinite;
  }

  @keyframes scrollBounce {
    0%,
    100% {
      transform: translateX(-50%) translateY(0);
      opacity: 1;
    }
    50% {
      transform: translateX(-50%) translateY(10px);
      opacity: 0.5;
    }
  }

  @media (max-width: 968px) {
    .hero {
      padding-top: 40px; /* Less top padding */
      flex-direction: column;
    }

    .hero-content {
      padding-block: var(--spacing-lg);
    }

    .hero-logo {
      margin-bottom: var(--spacing-sm);
    }

    .hero-logo img {
      width: clamp(200px, 60vw, 300px);
    }

    .hero-subtitle {
      font-size: 18px;
      margin-bottom: var(--spacing-md);
    }

    .hero-date {
      font-size: var(--font-size-base);
      margin-bottom: var(--spacing-md);
    }

    .hero-cta {
      flex-direction: row;
      gap: var(--spacing-sm);
      margin-bottom: var(--spacing-lg);
    }

    .hero-cta .btn {
      padding: 8px 16px;
      font-size: 0.75rem;
    }

    /* Show dancer on mobile - full viewport width, edge to edge */
    .hero-couple {
      position: relative;
      width: 100vw;
      max-width: none;
      margin: 0;
      margin-top: -70px;
      left: 50%;
      transform: translateX(-50%);
      bottom: auto;
      right: auto;
    }

    .hero-scroll {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding-top: 30px;
    }

    .hero-logo img {
      width: 70vw;
    }

    .hero-subtitle {
      font-size: 16px;
    }

    .hero-couple {
      width: 90%;
    }
  }
</style>
